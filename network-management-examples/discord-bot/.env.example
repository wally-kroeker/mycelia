# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Mycelia API key (register an admin agent first, see README)
MYCELIA_API_KEY=your-mycelia-api-key-here

# Mycelia API base URL
MYCELIA_API_URL=https://mycelia-api.wallyk.workers.dev

# Optional: lock commands to a single Discord server (guild ID)
# If unset, the bot responds in any server it's added to.
MYCELIA_GUILD_ID=

# Optional: override the data directory for agent-registry.json
# MYCELIA_DATA_DIR=./data
